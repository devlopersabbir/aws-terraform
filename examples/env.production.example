# ==============================================================================
# AWS DEPLOYMENT PLATFORM CONFIGURATION TEMPLATE
# Copy this file to '.env.production' at the root of your project and configure it.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. AWS Credentials & Target Region
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# ------------------------------------------------------------------------------
# 2. General Infrastructure Configuration
# ------------------------------------------------------------------------------
PROJECT_NAME=my-app-deployment
ENVIRONMENT=production

# ------------------------------------------------------------------------------
# 3. EC2 / Compute Configuration
# ------------------------------------------------------------------------------
INSTANCE_TYPE=t3.micro
SSH_PUBLIC_KEY_PATH=~/.ssh/id_rsa.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# ------------------------------------------------------------------------------
# 4. RDS / Database Configuration
# ------------------------------------------------------------------------------
DB_ENGINE=postgres
DB_ENGINE_VERSION=16.3
DB_INSTANCE_CLASS=db.t3.micro
DB_NAME=postgres
DB_USER=db_admin_user
DB_PASSWORD=ChooseASecureAndStrongPassword123!

# ------------------------------------------------------------------------------
# 5. S3 / Storage Configuration
# ------------------------------------------------------------------------------
BUCKET_NAME=my-app-assets-production-unique-name

# ------------------------------------------------------------------------------
# 6. Domain Name (For Caddy automatic SSL provisioning)
# ------------------------------------------------------------------------------
APP_DOMAIN=example.com
API_DOMAIN=api.example.com

# ------------------------------------------------------------------------------
# 7. Application Env Vars (Passed to Docker containers during runtime)
# ------------------------------------------------------------------------------
PORT=8080
JWT_SECRET=your_jwt_secret_key_here
NEXT_PUBLIC_API_URL=https://api.example.com
DATABASE_URL=postgresql://db_admin_user:ChooseASecureAndStrongPassword123!@db-host:5432/postgres
